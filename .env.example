# Copy this file to .env and fill in real values.
# See documentation/development.md for where to obtain each credential.

# Neon Postgres — full DSN used by Python (SQLAlchemy, alembic).
# Use the dev branch URL for local development; main branch URL goes in GitHub Actions secrets.
# https://neon.tech dashboard → Connection Details → Connection string
NEON_DATABASE_URL=postgresql://<neon_user>:<password>@<host>.neon.tech/<neon_dbname>?sslmode=require

# Neon Postgres — individual fields required by dbt-postgres (cannot accept a raw DSN).
# Parse these from the NEON_DATABASE_URL above.
NEON_HOST=<host>.neon.tech
NEON_USER=<neon_user>
NEON_PASSWORD=<password>
NEON_DBNAME=<neon_dbname>

# Cloudflare R2 credentials.
# https://dash.cloudflare.com → R2 Object Storage → Manage R2 API Tokens
#
# Bucket convention (mirrors the Neon dev/main split in ADR 0005):
#   - Local .env uses `<r2-bucket-name>` (the dev bucket).
#   - GitHub Actions repo secret R2_BUCKET_NAME is set to
#     `<r2-bucket-name>` (the prod bucket, written only by cron
#     workflows on the main branch).
# R2 has no native branching, so dev/prod isolation is bucket-level.
# API tokens can be scoped per-bucket; use separate tokens for local vs CI
# so a leaked dev token cannot write to the prod bucket.
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=<r2-bucket-name>

# DBT folder specifications
DBT_PROJECT_DIR=<dbt-project-dir>
DBT_PROFILES_DIR=<dbt-profile-dir>

# FDA iRES API credentials — Phase 5a only, not required until FDA extractor is implemented.
# Obtain from: https://open.fda.gov/apis/authentication/
# FDA_AUTHORIZATION_USER=<fda-username>
# FDA_AUTHORIZATION_KEY=<fda-api-key>
